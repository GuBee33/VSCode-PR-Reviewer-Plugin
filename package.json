{
  "name": "pr-reviewer",
  "displayName": "PR Reviewer – Copilot Edition",
  "description": "Review pull requests with GitHub Copilot, narrated by an animated cartoon character in the style of Ricky Gervais.",
  "version": "0.1.0",
  "publisher": "GuBee33",
  "repository": {
    "type": "git",
    "url": "https://github.com/GuBee33/VSCode-PR-Reviewer-Plugin"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copilot",
    "pull request",
    "code review",
    "ai"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "prReviewer.reviewPR",
        "title": "PR Reviewer: Review Current PR / Branch Diff",
        "icon": "$(play)"
      },
      {
        "command": "prReviewer.clearDecorations",
        "title": "PR Reviewer: Clear All Review Decorations"
      },
      {
        "command": "prReviewer.resetPanel",
        "title": "PR Reviewer: Reset Panel",
        "icon": "$(refresh)",
        "enablement": "view == prReviewer.characterView"
      },
      {
        "command": "prReviewer.openSettings",
        "title": "PR Reviewer: Settings",
        "icon": "$(gear)"
      },
      {
        "command": "prReviewer.browseIdleSprite",
        "title": "PR Reviewer: Browse Idle Sprite..."
      },
      {
        "command": "prReviewer.browseWorkSprite",
        "title": "PR Reviewer: Browse Work Sprite..."
      },
      {
        "command": "prReviewer.clearIdleSprite",
        "title": "PR Reviewer: Clear Custom Idle Sprite"
      },
      {
        "command": "prReviewer.clearWorkSprite",
        "title": "PR Reviewer: Clear Custom Work Sprite"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "prReviewerSidebar",
          "title": "PR Reviewer",
          "icon": "media/icon-sidebar.svg"
        }
      ]
    },
    "views": {
      "prReviewerSidebar": [
        {
          "type": "webview",
          "id": "prReviewer.characterView",
          "name": "Reviewer"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "prReviewer.reviewPR",
          "when": "view == prReviewer.characterView",
          "group": "navigation@1"
        },
        {
          "command": "prReviewer.resetPanel",
          "when": "view == prReviewer.characterView",
          "group": "navigation@2"
        },
        {
          "command": "prReviewer.openSettings",
          "when": "view == prReviewer.characterView",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "PR Reviewer",
      "properties": {
        "prReviewer.customIdleSprite": {
          "type": "string",
          "default": "",
          "description": "Path to a custom sprite sheet PNG for idle animation. Use command 'PR Reviewer: Browse Idle Sprite...' to select a file. Leave empty to use the bundled character."
        },
        "prReviewer.idleSpriteRows": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "Number of rows in the idle sprite sheet."
        },
        "prReviewer.idleSpriteCols": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "Number of columns in the idle sprite sheet."
        },
        "prReviewer.customWorkSprite": {
          "type": "string",
          "default": "",
          "description": "Path to a custom sprite sheet PNG for working animation. Use command 'PR Reviewer: Browse Work Sprite...' to select a file. Leave empty to use the bundled character."
        },
        "prReviewer.workSpriteRows": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "Number of rows in the work sprite sheet."
        },
        "prReviewer.workSpriteCols": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "Number of columns in the work sprite sheet."
        },
        "prReviewer.debugOutput": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug output in the 'PR Reviewer' output channel. Useful for troubleshooting."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}

{
  "name": "pr-reviewer",
  "displayName": "PR Reviewer – Copilot Edition",
  "description": "Review pull requests with GitHub Copilot, narrated by an animated cartoon character in the style of Ricky Gervais.",
  "version": "0.1.0",
  "publisher": "GuBee33",
  "repository": {
    "type": "git",
    "url": "https://github.com/GuBee33/VSCode-PR-Reviewer-Plugin"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copilot",
    "pull request",
    "code review",
    "ai"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "prReviewer.reviewPR",
        "title": "PR Reviewer: Review Current PR / Branch Diff",
        "icon": "$(play)"
      },
      {
        "command": "prReviewer.clearDecorations",
        "title": "PR Reviewer: Clear All Review Decorations"
      },
      {
        "command": "prReviewer.openSettings",
        "title": "PR Reviewer: Settings",
        "icon": "$(gear)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "prReviewerSidebar",
          "title": "PR Reviewer",
          "icon": "media/icon-sidebar.svg"
        }
      ]
    },
    "views": {
      "prReviewerSidebar": [
        {
          "type": "webview",
          "id": "prReviewer.characterView",
          "name": "Reviewer"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "prReviewer.reviewPR",
          "when": "view == prReviewer.characterView",
          "group": "navigation@1"
        },
        {
          "command": "prReviewer.openSettings",
          "when": "view == prReviewer.characterView",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "PR Reviewer",
      "properties": {
        "prReviewer.extraInstructions": {
          "type": "string",
          "default": "",
          "description": "Additional instructions appended to the review prompt, e.g. 'Focus on security issues only'."
        },
        "prReviewer.spritesheetPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to a custom PNG sprite sheet. Leave empty to use the bundled GuBee_SpriteSheet.png."
        },
        "prReviewer.spriteFrameWidth": {
          "type": "number",
          "default": 128,
          "description": "Display width (px) of a single frame. Defaults to 128 (tuned for the bundled GuBee sprite sheet)."
        },
        "prReviewer.spriteFrameHeight": {
          "type": "number",
          "default": 192,
          "description": "Display height (px) of a single frame. Defaults to 192 (tuned for the bundled GuBee sprite sheet)."
        },
        "prReviewer.spriteFrameCount": {
          "type": "number",
          "default": 4,
          "description": "Number of animation frames per row in the sprite sheet. Defaults to 4."
        },
        "prReviewer.spriteRowCount": {
          "type": "number",
          "default": 4,
          "description": "Number of animation rows in the sprite sheet (one per character state: idle, thinking, talking, laughing). Defaults to 4."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}
